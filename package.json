{
  "name": "orlando-photo-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && ng run orlando-photo-web:server:production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:image-dimensions": "node scripts/generate-image-dimensions.mjs",
    "generate:image-variants": "node scripts/generate-image-variants.mjs",
    "generate:images": "node scripts/generate-image-variants.mjs && node scripts/generate-image-dimensions.mjs && node scripts/generate-photo-sessions-gallery-data.mjs",
    "generate:photo-sessions-gallery": "node scripts/generate-photo-sessions-gallery-data.mjs",
    "convert:sources-to-webp": "node scripts/convert-sources-to-webp.mjs",
    "bundle:site-images": "node scripts/bundle-site-images.mjs",
    "sync:featured-sessions": "node scripts/sync-featured-session-filenames.mjs",
    "rename:featured-events": "node scripts/rename-featured-events.mjs",
    "rename:event-photos": "node scripts/rename-event-photos.mjs",
    "rename:photo-sessions": "node scripts/rename-photo-sessions.mjs",
    "dev:ssr": "ng run orlando-photo-web:serve-ssr",
    "serve:ssr": "node server.mjs",
    "build:ssr": "ng build && ng run orlando-photo-web:server",
    "prerender": "ng run orlando-photo-web:prerender",
    "analyze:bundle": "ng build --configuration production --source-map && source-map-explorer 'dist/orlando-photo-web/browser/main.*.js' --no-border-checks"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.2.13",
    "@angular/common": "~21.2.13",
    "@angular/compiler": "~21.2.13",
    "@angular/core": "~21.2.13",
    "@angular/forms": "~21.2.13",
    "@angular/platform-browser": "~21.2.13",
    "@angular/platform-browser-dynamic": "~21.2.13",
    "@angular/platform-server": "~21.2.13",
    "@angular/router": "~21.2.13",
    "@angular/ssr": "^21.2.11",
    "@vercel/analytics": "^2.0.1",
    "express": "^5.1.0",
    "rxjs": "~7.8.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.11",
    "@angular/cli": "~21.2.11",
    "@angular/compiler-cli": "~21.2.13",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "browser-sync": "^3.0.0",
    "image-size": "^2.0.2",
    "jasmine-core": "~5.4.0",
    "karma": "^6.4.2",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.0"
  }
}